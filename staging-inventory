; GLOBAL CONFIG ----------------------------
[all:vars]
; domain_name : folder inside ad/
domain_name=GOAD

; administrator user
admin_user=administrator

; environment
env=staging

; SSM connection (windows)
ansible_become=false
ansible_connection=aws_ssm
ansible_aws_ssm_bucket_name=dread-infra-alpha-operator-range-staging-us-west-1
ansible_aws_ssm_region=us-west-1
ansible_shell_type=powershell
ansible_aws_ssm_s3_addressing_style=virtual

; miscellaneous
data_path="{{ playbook_dir }}/../ad/GOAD/data"

; global settings inventory default value
keyboard_layouts=["en-US", "da-DK", "fr-FR"]

; modify this to add a default route
add_route=no
route_gateway=192.168.56.1
route_network=10.0.0.0/8

; modify this to enable http proxy
enable_http_proxy=no
ad_http_proxy=http://x.x.x.x:xxxx
ad_https_proxy=http://x.x.x.x:xxxx

;force_dns_server
force_dns_server=no
dns_server=1.1.1.1

;dns server forwarder
dns_server_forwarder=1.1.1.1

